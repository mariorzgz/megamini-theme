{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Brygada 1918 · Karla",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Karla",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"src": [
								"file:./assets/fonts/karla.woff2"
							]
						}
					],
					"fontFamily": "\"Karla\", sans-serif",
					"name": "Karla",
					"slug": "primary"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Brygada 1918",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/brygada-1918.woff2"
							]
						}
					],
					"fontFamily": "\"Brygada 1918\", serif",
					"name": "Brygada 1918",
					"slug": "secondary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "500",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "500"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontWeight": "500",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "500",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontWeight": "500",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			}
		}
	}
}
