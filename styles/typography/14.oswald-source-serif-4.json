{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Oswald · Source Serif 4",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontStyle": "normal",
							"fontWeight": "200 700",
							"src": [
								"file:./assets/fonts/oswald.woff2"
							]
						}
					],
					"fontFamily": "\"Oswald\", sans-serif",
					"name": "Oswald",
					"slug": "secondary"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Source Serif 4",
							"fontStyle": "normal",
							"fontWeight": "200 900",
							"src": [
								"file:./assets/fonts/source-serif-4.woff2"
							]
						}
					],
					"fontFamily": "\"Source Serif 4\", serif",
					"name": "Source Serif 4",
					"slug": "primary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "600"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "600"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "600"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			}
		}
	}
}
