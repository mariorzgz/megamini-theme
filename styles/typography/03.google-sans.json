{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Google Sans",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Google Sans",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/google-sans.woff2"
							]
						}
					],
					"fontFamily": "\"Google Sans\", sans-serif",
					"name": "Google Sans",
					"slug": "primary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "500"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
				}
			}
		}
	}
}
