{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Roboto Flex · Roboto Serif",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Roboto Flex",
							"fontStyle": "normal",
							"fontWeight": "100 1000",
							"src": [
								"file:./assets/fonts/roboto-flex.woff2"
							]
						}
					],
					"fontFamily": "\"Roboto Flex\", sans-serif",
					"name": "Roboto Flex",
					"slug": "secondary"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Roboto Serif",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/roboto-serif.woff2"
							]
						}					
					],
					"fontFamily": "\"Roboto Serif\", serif",
					"name": "Roboto Serif",
					"slug": "primary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "600",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "600"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "600"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontWeight": "600",
					"fontFamily": "var(--wp--preset--font-family--secondary)"
				}
			}
		}
	}
}
