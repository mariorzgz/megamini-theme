{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Literata",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Literata",
							"fontStyle": "normal",
							"fontWeight": "200 900",
							"src": [
								"file:./assets/fonts/literata.woff2"
							]
						}
					],
					"fontFamily": "\"Literata\", serif",
					"name": "Literata",
					"slug": "primary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "600"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontWeight": "600"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "600"
				}
			}
		}
	}
}
