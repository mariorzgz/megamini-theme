{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Roboto Serif",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Roboto Serif",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": [
								"file:./assets/fonts/roboto-serif.woff2"
							]
						}					
					],
					"fontFamily": "\"Roboto Serif\", serif",
					"name": "Roboto Serif",
					"slug": "primary"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
					
				}
			},
			"button": {
				"typography": {
					"fontWeight": "500"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"lineHeight": "1.6"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "-0.01em"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontWeight": "500"
				}
			}
		}
	}
}
