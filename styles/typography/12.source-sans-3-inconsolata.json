{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Source Sans 3 · Inconsolata",
	"settings": {
		"typography": {
			"fontFamilies": [				
				{
					"fontFace": [
						{
							"fontFamily": "Source Sans 3",
							"fontStyle": "normal",
							"fontWeight": "200 900",
							"src": [
								"file:./assets/fonts/source-sans-3.woff2"
							]
						}
					],
					"fontFamily": "\"Source Sans 3\", sans-serif",
					"name": "Source Sans 3",
					"slug": "secondary"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Inconsolata",
							"fontStyle": "normal",
							"fontWeight": "200 900",
							"src": [
								"file:./assets/fonts/inconsolata.woff2"
							]
						}
					],
					"fontFamily": "\"Inconsolata\", monospace",
					"name": "Inconsolata",
					"slug": "primary"
				}	
			]
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "500"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "500"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"lineHeight": "1.4"
		},
		"blocks": {
			"core/post-navigation-link": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "500"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "500"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontWeight": "500"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secondary)",
					"fontWeight": "500"
				}
			}
		}
	}
}
