					"slug": "secondary"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Border",
					"slug": "tertiary"
				}
			],
			"gradients": [
				{
					"name": "Base to Base 2",
					"slug": "base-to-base-2",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base), var(--wp--preset--color--base) 20%, var(--wp--preset--color--base-2))"
				},
				{
					"name": "Base to Base 3",
					"slug": "base-to-base-3",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base), var(--wp--preset--color--base) 20%, var(--wp--preset--color--base-3))"
				},
				{
					"name": "Base 2 to Base",
					"slug": "base-2-to-base",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base-2), var(--wp--preset--color--base) 80%, var(--wp--preset--color--base))"
				},
				{
					"name": "Base 3 to Base",
					"slug": "base-3-to-base",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base-3), var(--wp--preset--color--base) 80%, var(--wp--preset--color--base))"
				},
				{
					"name": "Base to Transparent",
					"slug": "base-to-transparent",
					"gradient": "linear-gradient(var(--wp--preset--color--base) 50%,transparent 50%)"
				},
				{
					"name": "Transparent to Base",
					"slug": "transparent-to-base",
					"gradient": "linear-gradient(transparent 50%, var(--wp--preset--color--base) 50%)"
				},
				{
					"name": "Accent",
					"slug": "accent",
					"gradient": "linear-gradient(180deg, oklch(from var(--wp--preset--color--accent) calc(l + .22) c h), var(--wp--preset--color--accent))"
				},
				{
					"name": "Diagonal Accent",
					"slug": "accent-diagonal",
					"gradient": "linear-gradient(135deg, oklch(from var(--wp--preset--color--accent) calc(l + .22) c h), var(--wp--preset--color--accent))"
				},
				{
					"name": "Analogous Accent",
					"slug": "accent-analogous",
					"gradient": "linear-gradient(135deg, oklch(from var(--wp--preset--color--accent) l c calc(h - var(--wp--custom--gradient-hue,45))), var(--wp--preset--color--accent), oklch(from var(--wp--preset--color--accent) l c calc(h + var(--wp--custom--gradient-hue,45))))"
				}	
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"color": {
					"text": "var:preset|color|base"
				}
			}
		}
	},
	"version": 3,
	"$schema": "https://schemas.wp.org/trunk/theme.json"
