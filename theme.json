{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#FAFAFA",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#FEFF00",
					"name": "Yellow",
					"slug": "yellow"
				},
				{
					"color": "#FF0000",
					"name": "Red",
					"slug": "red"
				},
				{
					"color": "#0050FF",
					"name": "Blue",
					"slug": "blue"
				},
				{
					"color": "#1C1C1C",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "color-mix(in srgb, currentColor 62%, transparent)",
					"name": "Secondary text",
					"slug": "secondary"
				},
				{
					"color": "color-mix(in srgb, currentColor 20%, transparent)",
					"name": "Border",
					"slug": "tertiary"
				}
			],
			"duotone": [
				{
					"name": "Grayscale",
					"slug": "grayscale",
					"colors": [
						"#000000",
						"#ffffff"
					]
				}
			],
			"gradients": [
				{
					"name": "Base to Base 2",
					"slug": "base-to-base-2",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base), var(--wp--preset--color--base) 20%, var(--wp--preset--color--base-2))"
				},
				{
					"name": "Base to Base 3",
					"slug": "base-to-base-3",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base), var(--wp--preset--color--base) 20%, var(--wp--preset--color--base-3))"
				},
				{
					"name": "Base 2 to Base",
					"slug": "base-2-to-base",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base-2), var(--wp--preset--color--base) 80%, var(--wp--preset--color--base))"
				},
				{
					"name": "Base 3 to Base",
					"slug": "base-3-to-base",
					"gradient": "linear-gradient(180deg, var(--wp--preset--color--base-3), var(--wp--preset--color--base) 80%, var(--wp--preset--color--base))"
				},
				{
					"name": "Base to Transparent",
					"slug": "base-to-transparent",
					"gradient": "linear-gradient(var(--wp--preset--color--base) 50%,transparent 50%)"
				},
				{
					"name": "Transparent to Base",
					"slug": "transparent-to-base",
					"gradient": "linear-gradient(transparent 50%, var(--wp--preset--color--base) 50%)"
				}
			]
		},
		"layout": {
			"contentSize": "44rem",
			"wideSize": "87rem"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"size": "4px",
					"slug": "5",
					"name": "4"
				},
				{
					"size": "8px",
					"slug": "10",
					"name": "8"
				},
				{
					"size": "16px",
					"slug": "15",
					"name": "16"
				},
				{
					"size": "24px",
					"slug": "20",
					"name": "24"
				},
				{
					"size": "clamp(24px, 2.734375vw, 32px)",
					"slug": "25",
					"name": "32 small"
				},
				{
					"size": "32px",
					"slug": "30",
					"name": "32"
				},
				{
					"size": "clamp(24px, 3.645833vw, 40px)",
					"slug": "35",
					"name": "40 small"
				},
				{
					"size": "clamp(36px, calc(36px + ((1vw - 6.4px) * 0.625)), 40px)",
					"slug": "40",
					"name": "40"
				},
				{
					"size": "clamp(24px, 4.166667vw, 48px)",
					"slug": "45",
					"name": "48 small"
				},
				{
					"size": "clamp(40px, calc(40px + ((1vw - 6.4px) * 1.25)), 48px)",
					"slug": "50",
					"name": "48"
				},
				{
					"size": "clamp(24px, 5vw, 64px)",
					"slug": "55",
					"name": "64 small"
				},
				{
					"size": "clamp(48px, calc(48px + ((1vw - 6.4px) * 2.5)), 64px)",
					"slug": "60",
					"name": "64"
				},
				{
					"size": "clamp(64px, calc(64px + ((1vw - 6.4px) * 2.5)), 80px)",
					"slug": "65",
					"name": "80"
				},
				{
					"size": "clamp(80px, calc(80px + ((1vw - 6.4px) * 3.125)), 100px)",
					"slug": "70",
					"name": "100"
				},
				{
					"size": "clamp(96px, calc(96px + ((1vw - 6.4px) * 3.75)), 120px)",
					"slug": "80",
					"name": "120"
				},
				{
					"size": "clamp(112px, calc(112px + ((1vw - 6.4px) * 7.5)), 160px)",
					"slug": "90",
					"name": "160"
				},
				{
					"size": "clamp(128px, calc(128px + ((1vw - 6.4px) * 11.25)), 200px)",
					"slug": "100",
					"name": "200"
				},
				{
					"size": "var(--wp--style--root--padding-left)",
					"slug": "site-padding",
					"name": "Site padding"
				},
				{
					"size": "auto",
					"slug": "auto",
					"name": "auto"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"dropCap": true,
			"defaultFontSizes": false,
			"fluid": {
				"minFontSize": "18px",
				"maxViewportWidth": "1280px",
				"minViewportWidth": "480px"
			},
			"fontFamilies": [
				{
					"fontFamily": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", Arial, sans-serif",
					"slug": "primary",
					"name": "System Sans Serif"
				}
			],
			"fontSizes": [
				{
					"name": "X-Small",
					"size": "0.875rem",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "1rem",
					"slug": "small"
				},
				{
					"name": "Normal",
					"size": "1.125rem",
					"slug": "normal"
				},
				{
					"name": "Medium",
					"fluid": {
						"min": "1.1875rem",
						"max": "1.3125rem"
					},
					"size": "21px",
					"slug": "medium"
				},
				{
					"name": "Large",
					"fluid": {
						"min": "1.3125rem",
						"max": "1.5rem"
					},
					"size": "24px",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"fluid": {
						"min": "1.5rem",
						"max": "2rem"
					},
					"size": "32px",
					"slug": "x-large"
				},
				{
					"name": "2X-Large",
					"fluid": {
						"min": "1.75rem",
						"max": "2.5rem"
					},
					"size": "40px",
					"slug": "xx-large"
				},
				{
					"name": "3X-Large",
					"fluid": {
						"min": "2rem",
						"max": "3rem"
					},
					"size": "48px",
					"slug": "3-x-large"
				},
				{
					"name": "4X-Large",
					"fluid": {
						"min": "2.25rem",
						"max": "4rem"
					},
					"size": "64px",
					"slug": "4-x-large"
				},
				{
					"name": "5X-Large",
					"fluid": {
						"min": "2.5rem",
						"max": "5rem"
					},
					"size": "80px",
					"slug": "5-x-large"
				}
			],
			"writingMode": true
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Light",
					"slug": "light",
					"shadow": "0px 4px 12px #00000014"
				},
				{
					"name": "Natural",
					"slug": "natural",
					"shadow": "0px 4px 16px #00000029"
				},
				{
					"name": "Deep",
					"slug": "deep",
					"shadow": "0px 4px 40px #00000033"
				},
				{
					"name": "Crisp",
					"slug": "crisp",
					"shadow": "0 0 0 2px #000, 6px 6px 0 2px #000"
				}
			]
		},
		"border": {
			"radiusSizes": [
				{
					"name": "Small",
					"slug": "small",
					"size": "4px"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "8px"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "16px"
				},
				{
					"name": "X-Large",
					"slug": "x-large",
					"size": "28px"
				}
			]
		},
		"custom": {
			"spacing": {
				"media": "var:preset|spacing|60",
				"heading-margin": "var:preset|spacing|60"
			},
			"main-width": "100vw",
			"font-mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
			"gradient-hue": 45,
			"title-width": "max(var(--wp--style--global--content-size), 62rem)"
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/columns": {
				"spacing": {
					"blockGap": {
						"left": "var:preset|spacing|30",
						"top": "var:preset|spacing|60"
					}
				}
			},
			"core/gallery": {
				"css": "--wp--style--gallery-gap-default:var(--wp--preset--spacing--15)"
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "var:preset|spacing|15"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"spacing": {
							"padding": {
								"top": "0.75rem",
								"bottom": "0.75rem",
								"left": "1.375rem",
								"right": "1.375rem"
							}
						},
						"border": {
							"color": "currentColor"
						}
					}
				}
			},
			"core/image": {
				"variations": {
					"rounded": {
						"border": {
							"radius": "16px"
						}
					}
				}
			},
			"core/social-links": {
				"spacing": {
					"blockGap": "var:preset|spacing|15"
				}
			},
			"core/quote": {
				"spacing": {
					"margin": {
						"left": "auto",
						"right": "auto"
					},
					"blockGap": "min(0.8em, 24px)"
				}
			},
			"core/pullquote": {
				"spacing": {
					"padding": {
						"top": "0",
						"bottom": "0"
					}
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "var:preset|font-size|x-large",
					"lineHeight": "1.2"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "0.9375rem"
						}
					}
				}
			},
			"core/heading" : {
				"css": "text-wrap: pretty; &:where(h1,h2) { text-wrap: balance } &:where(h1.has-text-align-center):not(.alignwide) { max-width: var(--wp--custom--title-width) }"
			},
			"core/post-title": {
				"css": ":where(h1) { text-wrap: balance; line-height: 1.125 } &:where(h1.has-text-align-center):not(.alignwide) { max-width: var( --wp--custom--title-width) }",
				"typography": {
					"lineHeight": "1.2"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/query-title" : {
				"css": ":where(h1) { text-wrap: balance }"
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "none"
							}
						},
						":focus": {
							"typography": {
								"textDecoration": "none"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|large",
					"fontWeight": "600",
					"lineHeight": "1.125"
				}
			},
			"core/post-terms": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/post-date": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/post-author-name": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/code": {
				"spacing": {
					"padding": "var:preset|spacing|15"
				},
				"typography": {
					"fontSize": "var:preset|font-size|x-small",
					"fontFamily": "var(--wp--custom--font-mono)"
				},
				"color": {
					"background": "color-mix(in srgb, currentColor 7%, transparent)"
				},
				"border": {
					"radius": "6px"
				}
			},
			"core/preformatted": {
				"typography": {
					"fontFamily": "var(--wp--custom--font-mono)"
				}
			},
			"core/post-navigation-link": {
				"typography": {
					"lineHeight": "1.25",
					"fontWeight": "600"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/query-pagination": {
				"spacing": {
					"blockGap": "var:preset|spacing|15",
					"margin": {
						"top": "var:preset|spacing|50"
					}
				},
				"typography": {
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|secondary"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"color": {
								"text": "currentColor"
							}
						}
					}
				}
			},
			"core/post-comments-form": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"elements": {
					"h3": {
						"typography": {
							"fontSize": "var:preset|font-size|normal"
						}
					}
				}
			},
			"core/comments-title": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "600"
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var:preset|font-size|x-small"
				},
				"color": {
					"text": "var:preset|color|secondary"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "var:preset|font-size|x-small"
				}
			},
			"core/comment-content": {
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"spacing": {
					"margin": {
						"top": "var:preset|spacing|10"
					}
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "var:preset|font-size|x-small",
					"fontWeight": "600"
				},
				"spacing": {
					"margin": {
						"top": "12px"
					}
				},
				"color": {
					"text": "var:preset|color|secondary"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/comments-pagination": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "500"
				},
				"spacing": {
					"blockGap": "4px"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|secondary"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/accordion": {
				"spacing": {
					"blockGap": "0px"
				}
			},
			"core/accordion-panel": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			},
			"core/details": {
				"css": "& summary{ font-weight: 500; line-height: 1.3;}"
			}
		},
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h1": {
				"typography": {
					"lineHeight": "1.125",
					"fontSize": "var:preset|font-size|4-x-large"
				}
			},
			"h2": {
				"typography": {
					"lineHeight": "1.125",
					"fontSize": "var:preset|font-size|3-x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|normal"
				}
			},
			"button": {
				"border": {
					"radius": "999px",
					"color": "transparent",
					"style": "solid",
					"width": "2px"
				},
				"color": {
					"background": "var:preset|color|accent",
					"text": "#ffffff"
				},
				"typography": {
					"fontWeight": "600",
					"lineHeight": "1.3"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "1.375rem",
						"right": "1.375rem"
					}
				}
			},
			"link": {
				"typography": {
					"textDecoration": "underline"
				},
				"color": {
					"text": "inherit"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline dotted"
					}
				}
			},
			"cite": {
				"typography": {
					"fontStyle": "normal",
					"fontSize": "clamp(0.9375rem,0.5625em,var(--wp--preset--font-size--large))",
					"lineHeight": "1.4"
				}
			},
			"caption": {
				"color": {
					"text": "var:preset|color|secondary"
				},
				"typography": {
					"fontSize": "var:preset|font-size|x-small",
					"lineHeight": "1.4"
				},
				"spacing": {
					"margin": {
